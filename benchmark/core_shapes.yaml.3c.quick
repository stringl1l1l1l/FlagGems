  shape_desc: "B, M, N, K"   # shapes are defined as (B, M, N, K)
  # qwen3-next
  # M = [1, 2, 4, 8, 16, 24, 32, 40, 48, 56, 64, 72, 80, 88, 96, 104, 112, 120, 128,
  #      136, 144, 152, 160, 168, 176, 184, 192, 200, 208, 216, 224, 232, 240, 248, 256,
  #      272, 288, 304, 320, 336, 352, 368, 384, 400, 416, 432, 448, 464, 480, 496, 512]  (cuda graph)
  # M = [768, 1024, 1536, 2048, 3072, 4096, 7168, 8192, 11264, 12280, 15360, 16384]
  # M_max = 16384 (prefill), 2048 (decode)
  # 1. GNDAttention：
  #   a. conv1d：[M, 4, 2048]
  #   b. in_proj_qkvz：[M, 2048, 3072]
  #   c. in_proj_ba：[M, 2048, 16]
  #   d. out_proj：[M, 1024, 2048]
  # 2. FullAttention:
  #   a. qkv_proj：[M, 2048, 2560]
  #   b. o_proj：[M, 1024, 2048]
  # 3. MoE
  #   a. gate：[M, 2048, 512]
  #   b. shared_expert/gate_up_proj：[M, 2048, 2560]
  #   c. shared_expert/down_proj：[M, 128, 2048]
  #   d. shared_expert_gate：[M, 2048, 1]
  # 4. LMHead
  #   a. [M, 2048, 37984]


groupmm:
  shapes:
    - [16, 512, 2048]
    - [16, 2560, 2048]
    - [64, 2048, 128]
  shape_desc: "Groups, N, K"   # shapes are defined as (Groups, N, K)

MvAndOuterBenchmark:
  shapes:
    - [384, 384]
    - [1024, 1024]
    - [4096, 4096]
    - [8192, 8192]
    - [10240, 10240]  #from perf

mm_self_transpose:
