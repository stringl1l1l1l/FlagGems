single_dim_shapes: &single_dim_shapes
  shapes:
    - [64]
    - [1024]
    - [2048]
    - [4096]
    - [65536]
  shape_desc: "M"

vdot:
  <<: *single_dim_shapes

randperm:
  <<: *single_dim_shapes

gelu_backward:
  shapes:
    - [1048576] # 1024 * 1024
    - [64, 64]
    - [4096, 4096]
    - [64, 512, 512]
    - [256, 1024, 1024]

cosh:
  shapes:
    - [4096, 4096]
    - [64, 512, 512]
    - [1024, 65536]
  shape_desc: "(B), M, N"

cosh_:
  shapes:
    - [4096, 4096]
    - [64, 512, 512]
    - [1024, 65536]
  shape_desc: "(B), M, N"

cosh_out:
  shapes:
    - [4096, 4096]
    - [64, 512, 512]
    - [1024, 65536]
  shape_desc: "(B), M, N"

log10:
  shapes:
    - [4096, 4096]
    - [64, 512, 512]
    - [1024, 65536]
  shape_desc: "(B), M, N"

log10_:
  shapes:
    - [4096, 4096]
    - [64, 512, 512]
    - [1024, 65536]
  shape_desc: "(B), M, N"

log10_out:
  shapes:
    - [4096, 4096]
    - [64, 512, 512]
    - [1024, 65536]
  shape_desc: "(B), M, N"

gcd:
  shapes:
    - [65536]
    - [1024, 1024]
    - [256, 4096]
    - [64, 256, 256]
  shape_desc: "(B), M, N"

softmax_backward:
  shapes:
    - [1048576] # 1024 * 1024
    - [64, 64]
    - [4096, 4096]
    - [64, 512, 512]
    - [256, 1024, 1024]

diag:
  shapes:
    - [64]
    - [1024]
    - [64, 64]
    - [256, 1024]
    - [1024, 1024]

quantile:
  shapes:
    - [1048576] # 1024 * 1024
    - [64, 64]
    - [4096, 256]
    - [64, 512, 128]
    - [20, 8, 10000]

