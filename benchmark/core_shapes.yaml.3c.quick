# default conv shape for input and weight stride padding groups
# default Ni Ci Hi WI  Co Hk Wk stride padding groups
Conv2DBenchmark:
  shapes:
    - [32, 64, 128, 128, 32, 3, 3, 1, 1, 1]
    - [104, 16, 32, 32, 32, 4, 4, 1, 0, 1]
